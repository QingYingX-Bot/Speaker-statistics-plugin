# 依赖目录
node_modules/

# Vue Web 源码目录（5.0.0 仅提交构建产物 resources/web）
/web/

# data 目录下的文件忽略规则（精确控制，而不是忽略整个目录）
# 忽略配置文件（这些是用户自定义的，不应该提交）
data/*.json
data/config/*.json
# 忽略数据库文件
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
# 忽略日志文件
data/*.log
# 忽略临时文件和备份目录
data/temp/
data/backups/
data/backgrounds/
# cache
data/cache/

# 其他通用忽略规则
*.db
*.db-journal
*.db-wal
*.db-shm
*.log
*.tmp
*.swp
*.swo
*~

# IDE 配置文件
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# 操作系统文件
Thumbs.db
.DS_Store
